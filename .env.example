# ================================================================
# HR BMW U11 Chatbot — Variables d'environnement
# ⚠️  JAMAIS commiter .env sur GitHub !
#     Copier ce fichier : cp .env.example .env
#     Puis remplir les valeurs réelles dans .env
# ================================================================

# ── n8n Serveur ─────────────────────────────────────────────────
# Après avoir configuré Cloudflare Tunnel, remplacer par votre domaine
N8N_HOST=votre-tunnel.trycloudflare.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://votre-tunnel.trycloudflare.com/
N8N_EDITOR_BASE_URL=https://votre-tunnel.trycloudflare.com/

# Clé de chiffrement n8n (32 chars minimum)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
N8N_ENCRYPTION_KEY=CHANGER_GENERER_UNE_CLE_32_CHARS_ICI

# ── Authentification interface n8n ──────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=MotDePasseAdmin2024!

# ── Neon PostgreSQL (gratuit) ───────────────────────────────────
# Récupérer depuis : console.neon.tech → votre projet → Connection string
# Cliquer sur "Connection string" et copier la valeur "Connection string" (psql)
# Format exact : postgresql://neondb_owner:npg_8aJpEbywQ6ZT@ep-tiny-glade-at3efk9k.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require
NEON_DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxx-xxx.eu-central-1.aws.neon.tech/hr_bmw_u11?sslmode=require

# ── Mot de passe formulaire upload ──────────────────────────────
UPLOAD_FORM_PASSWORD=BMW2024HR!

# ── WhatsApp Business Cloud API ─────────────────────────────────
# Récupérer depuis : developers.facebook.com → votre App → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=EAAG...votre_token_permanent_ici
WHATSAPP_PHONE_NUMBER_ID=1234567890123456
WHATSAPP_BUSINESS_ACCOUNT_ID=9876543210987654

# Choisir un token de vérification secret (vous le choisissez)
WHATSAPP_VERIFY_TOKEN=HRBMWVerify2024SecretToken

# Numéro dédié WhatsApp (ne pas modifier)
WHATSAPP_BOT_NUMBER=+21650505484
